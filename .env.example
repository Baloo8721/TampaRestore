# Environment Variables for Netlify Deployment
# Add these in Netlify Dashboard → Site Settings → Environment Variables

# ============ RESEND (Email) ============
# Get your free API key at https://resend.com
# 3,000 free emails/month
RESEND_API_KEY=re_your_api_key_here

# ============ SUPABASE (Database) ============
# Get these from your Supabase Dashboard → Settings → API
# Project URL (like: https://xxxxx.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anonymous key (like: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============ EMAILS ============
# Contractor email (where leads get sent)
CONTRACTOR_EMAIL=ctbelisle@gmail.com

# Admin email (you get copy of every lead)
ADMIN_EMAIL=tylerbelislefl@gmail.com

# ============ TWILIO (SMS) - Optional ============
# Get from https://console.twilio.com
# Add this later when you set up Twilio
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ============ DASHBOARD ============
DASHBOARD_PASSWORD=TampaRestore2026!